// Prisma Schema
// Compatible with Prisma 6

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== Enums ====================

enum UserRole {
  system_admin
  school_admin
  class_teacher
}

enum ProjectRole {
  lead
  care
  coordinate
}

enum RiskLevel {
  blue
  green
  yellow
  orange
  red
}

enum ActivityStatus {
  locked
  in_progress
  pending_assessment
  completed
}

enum ProblemType {
  internal
  external
}

enum DataManagementTargetType {
  school
  student
}

enum DataManagementAction {
  MARK_TEST_DATA
  UNMARK_TEST_DATA
  DISABLE
  RESTORE
  PERMANENT_DELETE
}

enum SystemAdminEventTargetType {
  school
  student
  user
  teacher
  counselingSession
  homeVisit
  phqResult
  activityProgress
  studentReferral
}

enum SystemAdminEventAction {
  EDIT
  CREATE
  DELETE
  RESET
}

// ==================== Models ====================



// School - โรงเรียน
model School {
  id          String    @id @default(cuid())
  name        String    // ชื่อโรงเรียน
  province    String?   // จังหวัด
  disabledAt  DateTime?
  disabledById String?
  disabledReason String? @db.Text
  restoredAt  DateTime?
  restoredById String?
  restoreReason String? @db.Text
  isTestData  Boolean   @default(false)
  testDataMarkedAt DateTime?
  testDataMarkedById String?
  testDataReason String? @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users          User[]
  teacherInvites TeacherInvite[]
  students       Student[]
  classes        SchoolClass[]
  teacherRoster  SchoolTeacherRoster[]

  @@index([disabledAt])
  @@index([isTestData])
  @@map("schools")
}

// School Class - ห้องเรียนของโรงเรียน (flexible, free-form)
model SchoolClass {
  id        String   @id @default(cuid())
  schoolId  String
  name      String   // free-form: "ม.1/1", "ป.6/2", อะไรก็ได้
  expectedStudentCount Int @default(0) // จำนวนนักเรียนจริงที่คาดไว้ ใช้คำนวณ coverage การคัดกรอง
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms  SchoolClassTerm[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("school_classes")
}

// School Class Term - จำนวนนักเรียนที่คาดไว้ของแต่ละห้อง แยกตามปีการศึกษา/เทอม
model SchoolClassTerm {
  id                   String   @id @default(cuid())
  schoolClassId        String
  academicYearId       String
  expectedStudentCount Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  schoolClass  SchoolClass  @relation(fields: [schoolClassId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([schoolClassId, academicYearId])
  @@index([academicYearId])
  @@map("school_class_terms")
}

// User Model for Authentication
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(school_admin) // effective role used by access control
  isPrimary     Boolean   @default(false) // true = primary school_admin for school-level management
  schoolId      String?   // FK to School
  deletedAt     DateTime? // soft delete timestamp; deleted users cannot sign in
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  school                School?             @relation(fields: [schoolId], references: [id])
  sessions              UserSession[]
  teacher               Teacher?
  teacherInvites        TeacherInvite[]
  phqResults            PhqResult[]
  assignedActivities    ActivityProgress[]  @relation("TeacherActivities")
  worksheetUploads      WorksheetUpload[]
  counselingSessions    CounselingSession[] @relation("CounselingSessions")
  schoolAdminInvites    SchoolAdminInvite[] @relation("CreatedSchoolAdminInvites")
  referralsFrom         StudentReferral[]   @relation("ReferralsFrom")
  referralsTo           StudentReferral[]   @relation("ReferralsTo")
  homeVisits            HomeVisit[]         @relation("HomeVisits")

  @@map("users")
  @@index([email])
  @@index([deletedAt])
}

// Stateful session - เก็บ session จริงไว้ฝั่ง server
model UserSession {
  id              String    @id @default(cuid())
  sessionTokenHash String    @unique
  userId          String
  expiresAt       DateTime
  lastActivityAt  DateTime
  tokenRotatedAt  DateTime  @default(now())
  userAgentLabel  String?
  userAgentHash   String?
  lastIpPrefix    String?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("user_sessions")
}

// Academic Year - ปีการศึกษาและเทอม
model AcademicYear {
  id          String    @id @default(cuid())
  year        Int       // ปีการศึกษา เช่น 2567
  semester    Int       // เทอม: 1 หรือ 2
  startDate   DateTime  // วันเริ่มเทอม
  endDate     DateTime  // วันสิ้นสุดเทอม
  isCurrent   Boolean   @default(false) // เทอมปัจจุบัน
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  phqResults     PhqResult[]
  schoolClassTerms SchoolClassTerm[]
  counselingSessions CounselingSession[]
  homeVisits     HomeVisit[]

  @@unique([year, semester]) // ห้ามซ้ำ ปี+เทอม
  @@map("academic_years")
}

// Teacher profile - ข้อมูลครู
model Teacher {
  id              String        @id @default(cuid())
  userId          String        @unique
  firstName       String        // ชื่อ
  lastName        String        // สกุล
  age             Int           // อายุ
  advisoryClass   String        // ชั้นที่ปรึกษา เช่น "ม.1/1"
  schoolRole      String        // บทบาทหน้าที่ในโรงเรียน
  projectRole     ProjectRole        // บทบาทในโครงการครูนางฟ้า: lead, care, coordinate
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("teachers")
}

// Teacher Invite - คำเชิญครูผู้ดูแล
model TeacherInvite {
  id              String    @id @default(cuid())
  token           String    @unique
  email           String
  firstName       String
  lastName        String
  age             Int
  userRole        UserRole  // target account role after accept invite
  advisoryClass   String
  schoolId        String
  schoolRole      String
  projectRole     ProjectRole    // target project role after accept invite
  invitedById     String
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())

  school          School       @relation(fields: [schoolId], references: [id])
  invitedBy       User         @relation(fields: [invitedById], references: [id])

  @@map("teacher_invites")
}

enum Gender {
  MALE
  FEMALE

  @@map("gender")
}

enum StudentStatus {
  ACTIVE
  RESIGNED
  TRANSFERRED
  GRADUATED
}

// Student - นักเรียน
model Student {
  id            String   @id @default(cuid())
  studentId     String   // รหัสนักเรียน (required)
  nationalId    String?  @unique @db.VarChar(13) // เลขบัตรประชาชน 13 หลัก (required สำหรับข้อมูลใหม่)
  firstName     String   // ชื่อ
  lastName      String   // สกุล
  gender        Gender?  // เพศ (optional เพื่อรองรับข้อมูลเก่า)
  age           Int?     // อายุ (optional เพื่อรองรับข้อมูลเก่า)
  class         String   // ห้อง เช่น "ม.1/1"
  schoolId      String   // FK to School
  status        StudentStatus @default(ACTIVE)
  statusChangedAt DateTime?
  leftAt        DateTime?
  disabledAt    DateTime?
  disabledById  String?
  disabledReason String? @db.Text
  restoredAt    DateTime?
  restoredById  String?
  restoreReason String? @db.Text
  isTestData    Boolean  @default(false)
  testDataMarkedAt DateTime?
  testDataMarkedById String?
  testDataReason String? @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school           School             @relation(fields: [schoolId], references: [id])
  phqResults       PhqResult[]
  activityProgress ActivityProgress[]
  counselingSessions CounselingSession[]
  referral         StudentReferral?
  homeVisits       HomeVisit[]

  @@unique([studentId, schoolId]) // ป้องกันซ้ำ: รหัสนักเรียน + โรงเรียน
  @@index([schoolId, class]) // For filtering by school and class
  @@index([disabledAt])
  @@index([isTestData])
  @@index([firstName, lastName]) // For name search
  @@map("students")
}

// Data Management Event - ประวัติการจัดการข้อมูลโดย system_admin
model DataManagementEvent {
  id             String                   @id @default(cuid())
  targetType     DataManagementTargetType
  targetId       String
  action         DataManagementAction
  reason         String                   @db.Text
  actorUserId    String
  actorSnapshot  Json
  targetSnapshot Json
  impactSnapshot Json
  warnings       Json?
  createdAt      DateTime                 @default(now())

  @@index([targetType, targetId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@map("data_management_events")
}

// System Admin Event - ประวัติการแก้ไขข้อมูลโดย system_admin
model SystemAdminEvent {
  id             String                     @id @default(cuid())
  targetType     SystemAdminEventTargetType
  targetId       String
  action         SystemAdminEventAction
  reason         String                     @db.Text
  actorUserId    String
  actorSnapshot  Json
  targetSnapshot Json
  changes        Json
  createdAt      DateTime                   @default(now())

  @@index([targetType, targetId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@map("system_admin_events")
}

// PHQ-A Result - ผลคัดกรองสุขภาพจิต
model PhqResult {
  id              String   @id @default(cuid())
  studentId       String   // FK to Student
  academicYearId  String   // FK to AcademicYear
  importedById    String?  // FK to User (ครูที่ import); nullable เมื่อบัญชีถูกลบถาวร
  importedBySnapshot Json? // snapshot ผู้ import สำหรับรักษาประวัติ
  assessmentRound Int      @default(1) // ครั้งที่ 1 หรือ 2
  
  // คะแนนแต่ละข้อ (0-3)
  q1              Int
  q2              Int
  q3              Int
  q4              Int
  q5              Int
  q6              Int
  q7              Int
  q8              Int
  q9              Int
  
  // ข้อพิเศษ (ตอบใช่/ไม่ใช่)
  q9a             Boolean  @default(false) // ความคิดทำร้ายตัวเอง
  q9b             Boolean  @default(false) // เคยพยายามทำร้ายตัวเอง
  
  // ผลคำนวณ
  totalScore      Int      // รวมคะแนน q1-q9
  riskLevel       RiskLevel   // BLUE, GREEN, YELLOW, ORANGE, RED
  referredToHospital Boolean @default(false) // ส่งต่อโรงพยาบาล
  hospitalName       String?                // ชื่อโรงพยาบาลที่ส่งต่อ
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student         Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear       @relation(fields: [academicYearId], references: [id])
  importedBy      User?              @relation(fields: [importedById], references: [id], onDelete: SetNull)
  activityProgress ActivityProgress[]

  @@unique([studentId, academicYearId, assessmentRound]) // ป้องกันซ้ำ
  @@index([studentId, createdAt(sort: Desc)]) // For DISTINCT ON latest per student
  @@index([studentId, createdAt(sort: Desc), riskLevel]) // For latest-risk dashboard filters
  @@index([studentId, academicYearId, assessmentRound]) // For trend queries
  @@index([studentId, academicYearId, createdAt(sort: Desc)]) // For latest-by-student within academic year
  @@index([academicYearId, createdAt(sort: Desc)]) // For year-filtered latest queries
  @@index([academicYearId]) // For year-filtered analytics (JOIN academic_years)
  @@map("phq_results")
}

// Activity Progress - ความคืบหน้ากิจกรรมช่วยเหลือนักเรียน
model ActivityProgress {
  id              String    @id @default(cuid())
  studentId       String    // FK to Student
  phqResultId     String    // FK to PhqResult (ผลคัดกรองที่ใช้)
  activityNumber  Int       // 1, 2, 3, 4, 5
  
  // สถานะ: locked, in_progress, pending_assessment, completed
  status          ActivityStatus    @default(locked)
  unlockedAt      DateTime? // วันที่ปลดล็อค
  completedAt     DateTime? // วันที่เสร็จสิ้น
  
  // ข้อมูลครู
  scheduledDate   DateTime? // วันที่นัดหมาย
  teacherId       String?   // FK to User (ครูผู้ทำกิจกรรม)
  teacherSnapshot Json?     // snapshot ครูผู้ทำกิจกรรมเมื่อบัญชีถูกลบถาวร
  teacherNotes    String?   // บันทึกของครู
  
  // แบบประเมินจากใบงาน
  internalProblems String?  // ปัญหาภายใน
  externalProblems String?  // ปัญหาภายนอก
  problemType      ProblemType?  // INTERNAL หรือ EXTERNAL
  assessedAt       DateTime? // วันที่ทำแบบประเมิน
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  student          Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  phqResult        PhqResult         @relation(fields: [phqResultId], references: [id])
  teacher          User?             @relation("TeacherActivities", fields: [teacherId], references: [id], onDelete: SetNull)
  worksheetUploads WorksheetUpload[]

  @@unique([studentId, phqResultId, activityNumber])
  @@index([phqResultId, status]) // For activity progress aggregation
  @@map("activity_progress")
}

// Worksheet Upload - ใบงานที่อัปโหลด
model WorksheetUpload {
  id                  String   @id @default(cuid())
  activityProgressId  String   // FK to ActivityProgress
  worksheetNumber     Int      @default(1) // ลำดับใบงาน (1, 2) — fixed, ไม่เปลี่ยนเมื่อลบ
  
  fileName            String   // ชื่อไฟล์
  fileUrl             String   // API path สำหรับไฟล์ (เสิร์ฟผ่าน /api/uploads)
  fileType            String   // image/jpeg, image/png, application/pdf
  fileSize            Int      // ขนาดไฟล์ (bytes)
  
  uploadedById        String?  // FK to User (ครูที่อัปโหลด); nullable เมื่อบัญชีถูกลบถาวร
  uploadedBySnapshot  Json?    // snapshot ผู้อัปโหลดสำหรับรักษาประวัติ
  idempotencyKey      String?  @unique @db.Uuid
  uploadedAt          DateTime @default(now())

  activityProgress    ActivityProgress @relation(fields: [activityProgressId], references: [id], onDelete: Cascade)
  uploadedBy          User?            @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@unique([activityProgressId, worksheetNumber])
  @@map("worksheet_uploads")
}

// Counseling Session - บันทึกการให้คำปรึกษารายบุคคล
model CounselingSession {
  id              String    @id @default(cuid())
  studentId       String    // FK to Student
  academicYearId  String?   // ปี/เทอมที่ผูกกับบันทึก
  sessionNumber   Int       // ครั้งที่
  sessionDate     DateTime  // วันที่
  counselorName   String    // ครูที่ปรึกษา
  summary         String    @db.Text // สรุปประเด็นที่ปรึกษา
  createdById     String?   // FK to User (ครูที่บันทึก); nullable เมื่อบัญชีถูกลบถาวร
  createdBySnapshot Json?   // snapshot ผู้บันทึกสำหรับรักษาประวัติ
  deletedAt       DateTime?
  deletedById     String?
  deleteReason    String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  createdBy       User?     @relation("CounselingSessions", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([studentId, sessionNumber])
  @@index([academicYearId])
  @@index([studentId, deletedAt])
  @@map("counseling_sessions")
}

// System Admin Whitelist - รายชื่อ email ที่สามารถเป็น system_admin ได้
model SystemAdminWhitelist {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("system_admin_whitelist")
}

// School Admin Invite - คำเชิญสร้างบัญชี school_admin
model SchoolAdminInvite {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String    @unique  // email ที่ระบุล่วงหน้า
  role      UserRole  @default(school_admin) // role ที่จะได้รับเมื่อ accept invite (ปัจจุบันใช้ school_admin)
  usedAt    DateTime?
  expiresAt DateTime
  createdBy String
  createdAt DateTime  @default(now())

  creator   User @relation("CreatedSchoolAdminInvites", fields: [createdBy], references: [id])

  @@map("school_admin_invites")
}

// School Teacher Roster - รายชื่อครูที่ลงไว้ล่วงหน้า (ก่อน invite)
model SchoolTeacherRoster {
  id              String       @id @default(cuid())
  schoolId        String
  firstName       String
  lastName        String
  email           String?      // optional — ใช้ pre-fill invite
  age             Int          // อายุ
  userRole        UserRole     // school_admin | class_teacher
  advisoryClass   String       // ห้องที่ปรึกษา (class_teacher) หรือ "ทุกห้อง" (school_admin)
  schoolRole      String       // บทบาทในโรงเรียน
  projectRole     ProjectRole  // lead, care, coordinate
  inviteSent      Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, email])
  @@index([schoolId])
  @@map("school_teacher_roster")
}

// Password Reset Token - โทเค็นรีเซ็ตรหัสผ่าน
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@map("password_reset_token")
}

// Student Referral - ส่งต่อนักเรียนระหว่างครู
model StudentReferral {
  id                String   @id @default(cuid())
  studentId         String   @unique  // 1 referral ต่อ 1 นักเรียน
  fromTeacherUserId String   // userId ครูที่ส่งต่อ
  toTeacherUserId   String   // userId ครูที่รับดูแล
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fromTeacher User    @relation("ReferralsFrom", fields: [fromTeacherUserId], references: [id])
  toTeacher   User    @relation("ReferralsTo", fields: [toTeacherUserId], references: [id])

  @@index([fromTeacherUserId])
  @@index([toTeacherUserId])
  @@map("student_referrals")
}

// Home Visit - บันทึกการเยี่ยมบ้านนักเรียน
model HomeVisit {
  id                String    @id @default(cuid())
  studentId         String
  academicYearId    String?   // ปี/เทอมที่ผูกกับบันทึก
  visitNumber       Int       // ครั้งที่ (auto-increment per student)
  visitDate         DateTime
  description       String    @db.Text
  nextScheduledDate DateTime?
  teacherName       String    // snapshot ชื่อครู
  teacherRole       String    // snapshot บทบาทครู
  createdById       String?
  createdBySnapshot Json?   // snapshot ผู้บันทึกสำหรับรักษาประวัติ
  deletedAt         DateTime?
  deletedById       String?
  deleteReason      String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  student   Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  createdBy User?           @relation("HomeVisits", fields: [createdById], references: [id], onDelete: SetNull)
  photos    HomeVisitPhoto[]

  @@unique([studentId, visitNumber])
  @@index([academicYearId])
  @@index([studentId, deletedAt])
  @@map("home_visits")
}

// Home Visit Photo - รูปภาพการเยี่ยมบ้าน
model HomeVisitPhoto {
  id          String   @id @default(cuid())
  homeVisitId String
  fileName    String
  fileUrl     String
  fileType    String
  fileSize    Int
  idempotencyKey String? @unique @db.Uuid
  uploadedAt  DateTime @default(now())

  homeVisit HomeVisit @relation(fields: [homeVisitId], references: [id], onDelete: Cascade)

  @@map("home_visit_photos")
}

model FileDeletionOutbox {
  id            String    @id @default(cuid())
  fileUrl       String    @unique
  attempts      Int       @default(0)
  nextAttemptAt DateTime  @default(now())
  processedAt   DateTime?
  lastError     String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([processedAt, nextAttemptAt])
  @@map("file_deletion_outbox")
}
